# =============================================================================
# Vox-SN — Variables d'environnement
# Copier ce fichier en .env avant de lancer docker compose up
#   cp .env.example .env
# =============================================================================

# --- Identifiant du projet ---
PROJECT_NAME=vox-sn
PROJECT_VERSION=1.0.0

# --- Sécurité Privacy ---
# Sel pour SHA-256 sur user_id (à changer en production !)
CITIZEN_SECRET_SALT=UADB_VOX_2025_CHANGEME

# --- Kafka ---
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC_RAW=social_raw
KAFKA_TOPIC_ANALYZED=social_analyzed
KAFKA_TOPIC_AGG=social_sentiment_agg
KAFKA_AUTO_CREATE_TOPICS=true

# --- Spark ---
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g
SPARK_SHUFFLE_PARTITIONS=4
SPARK_NLP_VERSION=5.1.4

# --- HBase ---
HBASE_HOST=hbase
HBASE_THRIFT_PORT=9090
HBASE_WEB_PORT=16010

# --- Hive ---
HIVE_HOST=hive-metastore
HIVE_PORT=10000
HIVE_DATABASE=vox_sn

# --- Airflow ---
AIRFLOW_UID=50000
AIRFLOW_GID=0
AIRFLOW_WEB_PORT=8082
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=vox_sn_classifier

# --- Pipeline ---
PRODUCER_RATE_SECONDS=2
WINDOW_DAYS_RETRAIN=30
SENTIMENT_CRISIS_THRESHOLD=-0.5
SENTIMENT_WARNING_THRESHOLD=-0.2

# --- Java ---
JAVA_HOME=/usr/lib/jvm/java-11-openjdk-amd64
